[Unit]
Description=ipoed
Before=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/default/ipoed
Type=simple
ExecStartPre=/bin/ip link set up dev $WAN_IF
ExecStartPre=/bin/ip link set up dev $LAN_IF
ExecStartPre=/bin/sleep 5
ExecStart=/usr/sbin/ipoed --wan-if $WAN_IF --lan-if $LAN_IF $IPOED_OPTS

[Install]
WantedBy=network.target
Alias=ipoed.service
